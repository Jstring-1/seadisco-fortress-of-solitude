# SeaDisco env vars. Copy this file to .env and fill in the values.

# Postgres (Railway provides this automatically in production)
APP_DB_URL=postgresql://user:pass@host:5432/dbname

# Clerk auth — get these from https://dashboard.clerk.com
AUTH_PK=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk user id of the admin (gates /admin dashboard and the LOC view)
ADMIN_CLERK_ID=user_xxxxxxxxxxxxxxxxxxxxxxx

# Discogs OAuth 1.0a — register at https://www.discogs.com/settings/developers
DISCOGS_CONSUMER_KEY=your_consumer_key
DISCOGS_CONSUMER_SECRET=your_consumer_secret

# Anthropic API key for AI-powered search recommendations
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: port (defaults to 3001)
# PORT=3001
