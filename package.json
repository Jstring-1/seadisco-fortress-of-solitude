{
  "name": "discogs-mcp",
  "version": "1.0.0",
  "description": "MCP server for the Discogs API",
  "type": "module",
  "main": "dist/http-server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/search-api.js",
    "start:stdio": "node dist/index.js",
    "start:web": "node dist/search-api.js",
    "seed": "node scripts/seed-searches.js",
    "sync-fresh": "node scripts/sync-fresh-releases.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@modelcontextprotocol/sdk": "^1.10.1",
    "express": "^4.21.2",
    "nodemailer": "^8.0.3",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "typescript": "^5.5.0"
  }
}
